# =============================================================================
# Self-signed certificates
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# Let's Encrypt
.well-known/

# Testing and Development
# =============================================================================
# Test coverage
coverage/
.nyc_output/
*.lcov

# Test results
test-results/
test-reports/
junit.xml

# Cypress
cypress/videos/
cypress/screenshots/
cypress/downloads/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Jest
.jest/

# Storybook
storybook-static/

# Documentation builds
docs/build/
docs/_build/

# Monitoring and Logs
# =============================================================================
# Application logs
logs/
*.log

# PM2 logs
.pm2/

# Docker logs
docker-logs/

# System logs
syslog/
messages/

# Backup Files
# =============================================================================
# Database backups
*.backup
*.bak
*.sql.bak

# File backups
*.backup
*.bak
*.old
*.orig
*.save

# Archive files
*.zip
*.tar.gz
*.rar
*.7z

# Configuration Overrides
# =============================================================================
# Local configuration overrides
config.local.js
config.local.json
settings.local.js
settings.local.json

# User-specific configurations
.user-config
.user-settings

# Package Manager Files
# =============================================================================
# npm
.npmrc
.npmignore

# Yarn
.yarnrc
.yarnrc.yml
.yarn-integrity

# pnpm
.pnpmrc
pnpm-lock.yaml

# Lerna
lerna.json

# Workspace files
pnpm-workspace.yaml
yarn.workspaces

# Security and Secrets
# =============================================================================
# API keys and secrets
secrets/
.secrets
api-keys.json
secrets.json

# SSH keys
.ssh/
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# GPG keys
*.gpg
*.asc

# Environment-specific files
.env.production
.env.staging
.env.local
.env.*.local

# Keep example files
!env.example
!*.env.example

# =============================================================================
# IMPORTANT NOTES:
# =============================================================================
# 1. Never commit .env files with real secrets
# 2. Keep env.example files for reference
# 3. Use environment variables for configuration
# 4. Consider using a secrets management service
# 5. Regularly review what's being ignored
# =============================================================================
