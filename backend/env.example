# ==========================================
# 🔐 MANDATORY SERVER CONFIGURATION
# ==========================================

# Port the backend server will run on
PORT=3001

# Production secret for session encryption (MANDATORY in production)
# Generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_long_random_session_secret_here

# Frontend URL for CORS and redirects
# Must match your actual frontend deployment URL (e.g., https://movemyplaylist.online)
FRONTEND_URL=http://localhost:3000

# Node Environment
NODE_ENV=development

# ==========================================
# 🛠️ OPTIONAL PLATFORM CONFIGURATION (BYOK)
# ==========================================
# If these are left blank, the app will operate in "Bring Your Own Key" mode
# and will prompt users to provide their own credentials in the UI.

# Spotify API Configuration
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3001/auth/spotify/callback

# YouTube API Configuration
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3001/auth/youtube/callback
YOUTUBE_API_KEY=

# ==========================================
# 📊 OPTIONAL FIREBASE CONFIGURATION (STATS)
# ==========================================
# Required only if you want to track global transfer statistics
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Alternative: Use service account JSON key string directly
# FIREBASE_SERVICE_ACCOUNT_KEY=
